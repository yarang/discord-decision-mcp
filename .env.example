# Discord Decision MCP 환경변수 설정 예시
# 이 파일을 복사하여 .env로 이름을 바꾸고 실제 값으로 수정하세요.

# ── 필수 설정 ──────────────────────────────────────────────────────

# Discord Bot Token
# Discord Developer Portal에서 생성한 Bot의 Token
# "Bot " 접두사를 포함해야 합니다
DISCORD_BOT_TOKEN=Bot YOUR_BOT_TOKEN_HERE

# Discord Channel ID
# 질문을 보낼 기본 채널의 ID (숫자만)
# 채널 우클릭 → ID 복사 (개발자 모드 필요)
DISCORD_CHANNEL_ID=123456789012345678

# ── 선택 설정 ──────────────────────────────────────────────────────

# 프로젝트 이름
# question_id 생성에 사용됨 (기본값: project)
PROJECT_NAME=my-project

# Pending 상태 파일 저장 경로
# 프로세스 재시작 후에도 대기 중인 질문을 복원하기 위해 사용
# (기본값: ~/.claude/pending_decisions)
PENDING_DIR=~/.claude/pending_decisions

# Discord polling 간격 (초)
# 사용자 응답을 확인하는 주기 (기본값: 5)
POLL_INTERVAL_SECONDS=5
